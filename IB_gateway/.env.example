# Never put real credentials or secrets in this repository. For local real-mode
# testing, copy these names to an environment file outside the repository and
# restrict that file to its owner.

# Application (PORT and APP_BASE_PATH are supplied by the Backend for QCH children.)
PORT=8080
APP_BASE_PATH=
FORWARDED_ALLOW_IPS=*

# Authentication (required in both ib_async and mock modes; replace placeholders at runtime.)
DJANGO_SECRET_KEY=replace-me
GATEWAY_SERVICE_TOKEN=replace-me

# IBKR credentials (required for ib_async; supplied by the Backend; optional in mock mode.)
IB_USERNAME=
IB_PASSWORD=
IBKR_CLIENT_ID=17

# IBKR mode (required for ib_async; paper or live; supplied by the Backend.)
IBC_TRADING_MODE=paper

# Broker adapter (ib_async is the deployment default; mock is test-only.)
BROKER_ADAPTER=ib_async

# noVNC (required in both modes; supplied by the Backend for QCH children.)
NOVNC_PASSWORD=replace-me

# IBC (optional tuning; defaults shown.)
TWS_MAJOR_VRSN=1045
IBC_AUTO_RESTART_TIME=11:45 PM
IBC_2FA_TIMEOUT=180

# Storage (optional; the QCH API currently does not attach persistent volumes.)
GATEWAY_DB_PATH=/data/gateway.sqlite3

# Runtime tuning (optional; defaults shown.)
BROKER_REFRESH_SECONDS=5
GATEWAY_EVENT_RETENTION_DAYS=7
GATEWAY_HEALTH_RETENTION_DAYS=7
GATEWAY_COMPACTION_SECONDS=3600
GATEWAY_COMPACTION_BATCH_SIZE=1000
