# QFS Frontend application (root/build context: Frontend)
PORT=5173
BACKEND_API_URL=https://qfsplatform.com/trading_eng_backend/api/v1

# Build-time base. The Dockerfile already supplies this production default.
VITE_APP_BASE_PATH=/trading_eng_frontend/
# Optional non-Docker/local Vite override; Docker uses BACKEND_API_URL at runtime.
VITE_API_BASE_URL=http://localhost:8000/api/v1
