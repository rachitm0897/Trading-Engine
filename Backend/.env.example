# QFS Backend application (root/build context: Backend)
PORT=8000
APP_BASE_PATH=/trading_eng_backend
PUBLIC_BASE_URL=https://qfsplatform.com/trading_eng_backend
FORWARDED_ALLOW_IPS=*
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
ALLOWED_HOSTS=qfsplatform.com
CORS_ALLOWED_ORIGINS=https://qfsplatform.com
CSRF_TRUSTED_ORIGINS=https://qfsplatform.com

# External infrastructure; none of these services is supplied by the three QFS apps.
DATABASE_URL=postgresql://USER:PASSWORD@POSTGRES_HOST:5432/trading_engine
REDIS_URL=redis://REDIS_HOST:6379/0
CELERY_BROKER_URL=redis://REDIS_HOST:6379/1
CELERY_RESULT_BACKEND=redis://REDIS_HOST:6379/2
KAFKA_BOOTSTRAP_SERVERS=KAFKA_HOST:9092
KAFKA_ENABLED=true
FLINK_REST_URL=https://FLINK_HOST

# Private per-session QCH children. QFS/QCH injects the first three values.
QCH_APP_ID=
QCH_API_HOST=
QCH_SERVICE_TOKEN=
QCH_REQUEST_TIMEOUT_SECONDS=10
QCH_SUBCONTAINER_NETWORK=traefik
# Use the immutable Docker Hub digest form in production.
IBKR_GATEWAY_IMAGE=docker.io/DOCKERHUB_USERNAME/trading-engine-ib-gateway@sha256:REPLACE_WITH_64_HEX_DIGEST
# Testing alternative (replace the line above):
# IBKR_GATEWAY_IMAGE=docker.io/DOCKERHUB_USERNAME/trading-engine-ib-gateway:v1.0.0
# A fixed non-latest tag is accepted for testing; latest is rejected.
# The same reference works while the Docker Hub repository is private or public.
# Repository visibility is not controlled or detected by the Backend.
# Private repositories require Docker Hub read authentication on the QCH/Docker host;
# public repositories require no Docker Hub authentication. Making a repository public
# requires no Backend code change. Never store Docker Hub credentials in the Backend.
BROKER_SESSION_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
BROKER_CREDENTIAL_TTL_SECONDS=900
BROKER_SESSION_CREATING_STALE_SECONDS=60
BROKER_SESSION_START_TIMEOUT_SECONDS=45
BROKER_SESSION_HEALTH_TIMEOUT_SECONDS=5
BROKER_STATIC_DEVELOPMENT_GATEWAY_ENABLED=false
NOVNC_ACCESS_TOKEN_TTL_SECONDS=300
NOVNC_PROXY_CONNECT_TIMEOUT_SECONDS=10
NOVNC_PROXY_IDLE_TIMEOUT_SECONDS=300
NOVNC_PROXY_MAX_BODY_BYTES=10485760

# Trading and market-data controls.
NEW_EXECUTION_MODE=SHADOW
ALLOW_LIVE_TRADING=false
GLOBAL_KILL_SWITCH=false
MARKET_PRICE_STALE_SECONDS=300
WARMUP_TIMEOUT_SECONDS=300
MARKET_CONSUMER_HEARTBEAT_STALE_SECONDS=30
KAFKA_LAG_DEGRADED_THRESHOLD=1000

# Finnhub and fallback policy.
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_API_KEY_OVERRIDE_ENABLED=false
FINNHUB_REQUEST_TIMEOUT_SECONDS=15
FINNHUB_MAX_RETRIES=2
FINNHUB_ENCRYPTION_KEY=
FINNHUB_OPERATION_THROTTLE_LIMIT=30
MARKET_DATA_FALLBACK_ENABLED=false
FINNHUB_HISTORICAL_FALLBACK_ENABLED=false
FINNHUB_LIVE_FALLBACK_ENABLED=false
FINNHUB_AUTO_FAILBACK_ENABLED=false
IBKR_MARKET_DATA_FAILOVER_GRACE_SECONDS=15
FINNHUB_LIVE_STALE_SECONDS=15
FINNHUB_WS_URL=wss://ws.finnhub.io
FINNHUB_WS_RECONNECT_MAX_SECONDS=30
FINNHUB_ALLOWED_LATENESS_SECONDS=2
FINNHUB_WS_RECONCILE_SECONDS=2
PRIMARY_RECOVERY_CONFIRMATION_EVENTS=3
PRIMARY_PROBE_RETRY_SECONDS=30
FINNHUB_MAPPING_REVALIDATE_SECONDS=86400
FINNHUB_SUPPORTED_ASSET_CLASSES=STK

# Packaged research bundle and external/provider-backed research execution.
RESEARCH_ENABLED=true
RECOMMENDATION_SYSTEM_ENABLED=true
RECOMMENDATION_UNIVERSE_KEY=US_LARGE_CAP_GICS
RECOMMENDATION_MAX_STOCKS=20
RECOMMENDATION_MIN_STOCKS=5
RECOMMENDATION_CANDIDATE_POOL_SIZE=100
RECOMMENDATION_MAX_STRATEGIES_PER_STOCK=1
RESEARCH_BUNDLE_PATH=/app/research_bundle
RESEARCH_ARTIFACT_ROOT=/app/research_artifacts
RESEARCH_DAILY_LOOKBACK_YEARS=10
RESEARCH_INTRADAY_LOOKBACK_DAYS=90
RESEARCH_MINIMUM_DAILY_BARS=756
RESEARCH_MAX_PARALLEL_DATA_TASKS=8
RESEARCH_MAX_PARALLEL_BACKTEST_TASKS=8
RESEARCH_DAILY_PROVIDER=FINNHUB
RESEARCH_SCORE_MAX_AGE_DAYS=7
RESEARCH_STALE_SCORE_FALLBACK_DAYS=30
RECOMMENDATION_SNAPSHOT_MAX_AGE_HOURS=24
