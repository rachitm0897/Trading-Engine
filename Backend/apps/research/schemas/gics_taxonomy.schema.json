{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "required": ["metadata", "sectors"],
  "properties": {
    "metadata": {"type": "object"},
    "sectors": {
      "type": "array", "minItems": 11, "maxItems": 11,
      "items": {
        "type": "object", "required": ["code", "name", "industry_groups"],
        "properties": {"code": {"type": "string", "pattern": "^[0-9]{2}$"}, "name": {"type": "string"}, "industry_groups": {"type": "array"}}
      }
    }
  }
}
