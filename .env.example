# Optional local infrastructure overrides. Do not put production credentials here.
POSTGRES_DB=trading_engine
POSTGRES_USER=trading
POSTGRES_PASSWORD=replace-with-a-local-only-password
POSTGRES_PORT=5433

# Flink operational policy used by the local Compose stack.
MARKET_PRICE_STALE_SECONDS=300
KAFKA_STARTING_OFFSETS=committed
KAFKA_STARTING_OFFSETS_MARKET_NORMALIZATION_V1=committed
KAFKA_STARTING_OFFSETS_BAR_AGGREGATION_V2=committed
KAFKA_STARTING_OFFSETS_INDICATOR_COMPUTATION_V2=committed
KAFKA_STARTING_OFFSETS_STALE_PRICE_DETECTION_V1=committed
KAFKA_STARTING_OFFSETS_STREAM_HEALTH_V1=committed
UNKNOWN_CONID_BUFFER_TIMEOUT_MS=30000
UNKNOWN_CONID_BUFFER_MAX_EVENTS=1000
DEDUPLICATION_STATE_TTL_SECONDS=86400
FLINK_PROCESSING_MODE=
