# Standalone Backend QFS application (repository root/build context: .)
PORT=8000
APP_BASE_PATH=/trading_eng_backend
PUBLIC_BASE_URL=https://qfsplatform.com/trading_eng_backend
FORWARDED_ALLOW_IPS=*
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
ALLOWED_HOSTS=qfsplatform.com
CORS_ALLOWED_ORIGINS=https://qfsplatform.com
CSRF_TRUSTED_ORIGINS=https://qfsplatform.com

# External infrastructure belongs only to the Backend QFS application.
DATABASE_URL=postgresql://USER:PASSWORD@POSTGRES_HOST:5432/trading_engine
REDIS_URL=redis://REDIS_HOST:6379/0
CELERY_BROKER_URL=redis://REDIS_HOST:6379/1
CELERY_RESULT_BACKEND=redis://REDIS_HOST:6379/2
PORTFOLIO_TARGET_MAX_AGE_SECONDS=900
PORTFOLIO_TARGET_COORDINATION_DEBOUNCE_SECONDS=2
PORTFOLIO_TARGET_COORDINATION_BATCH_SIZE=50
KAFKA_BOOTSTRAP_SERVERS=KAFKA_HOST:9092
KAFKA_ENABLED=true
FLINK_REST_URL=https://FLINK_HOST

# QCH injects these three values into the Backend process.
QCH_APP_ID=
QCH_API_HOST=
QCH_SERVICE_TOKEN=

# Managed private child containers.
IBKR_GATEWAY_IMAGE=docker.io/rachitm4555/trading-engine-ib-gateway@sha256:0bcf05605fb3be5a5f2aa70adef3e5eeef111dc59f6f569848c5ee0be785479d
BROKER_SESSION_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
# Optional: leave blank to use QCH's platform-default network.
QCH_SUBCONTAINER_NETWORK=

# Operational policy overrides.
NEW_EXECUTION_MODE=SHADOW
ALLOW_LIVE_TRADING=false
GLOBAL_KILL_SWITCH=false
FINNHUB_API_KEY=
FINNHUB_ENCRYPTION_KEY=
FINNHUB_API_KEY_OVERRIDE_ENABLED=false
MARKET_DATA_FALLBACK_ENABLED=false
FINNHUB_HISTORICAL_FALLBACK_ENABLED=false
FINNHUB_LIVE_FALLBACK_ENABLED=false
FINNHUB_AUTO_FAILBACK_ENABLED=false
RESEARCH_ENABLED=true
RECOMMENDATION_SYSTEM_ENABLED=true
RESEARCH_BUNDLE_PATH=/app/research_bundle
RESEARCH_ARTIFACT_ROOT=/app/research_artifacts
RESEARCH_DAILY_PROVIDER=FINNHUB
RESEARCH_MAX_PARALLEL_DATA_TASKS=8
RESEARCH_MAX_PARALLEL_BACKTEST_TASKS=8
